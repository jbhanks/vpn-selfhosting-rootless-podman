server {
    listen {{ WG_SERVER_IP }}:80;
    server_name {{ DASHY_HOST }} {{ DOMAIN }};
    return 301 https://$host$request_uri;
}
server {
    listen {{  WG_SERVER_IP }}:443 ssl;
    http2 on;
    server_name {{ DASHY_HOST }} {{ DOMAIN }};

    include /etc/nginx/default.d/*.conf;

    access_log /var/log/nginx/{{ DASHY_HOST }}_access.log main;
    error_log  /var/log/nginx/{{ DASHY_HOST }}_error_log warn;

    location / {
        proxy_pass http://127.0.0.1:{{ DASHY_PORT }}/;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout 3600;
    }
}
